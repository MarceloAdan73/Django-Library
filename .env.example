# ==============================================
# Django Library - Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# Django Security
SECRET_KEY=change-this-to-a-secure-random-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Admin User (OPTIONAL - leave empty for auto-generated secure password)
# If set, this password will be used for the admin account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Google Books API (optional - for higher rate limits)
GOOGLE_BOOKS_API_KEY=

# Database (Render provides PostgreSQL automatically)
# Leave empty for local SQLite development
DATABASE_URL=
